{
  "name": "simulador-credito",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config demo/vite.config.ts",
    "build:widget": "cross-env BUILD_MODE=es vite build && cross-env BUILD_MODE=iife vite build",
    "build:demo": "vite build --config demo/vite.config.ts",
    "build": "pnpm build:widget && pnpm build:demo",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@vercel/node": "^4.0.0",
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
